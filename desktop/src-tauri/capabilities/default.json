{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core window permissions plus permission to execute the bundled backend sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/tcg-backend",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            "8000",
            "--log-level",
            "warning"
          ]
        }
      ]
    }
  ]
}
