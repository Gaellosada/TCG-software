# npm deps for the Tauri CLI wrapper.
node_modules/

# The staged sidecar binary is a build artifact (~90 MB); rebuild via
# sidecar/build_sidecar.sh. The directory is recreated by the build script and
# CI (mkdir -p) before staging, so we don't track a .gitkeep placeholder.
src-tauri/binaries/*

# PyInstaller intermediate output.
sidecar/build/
sidecar/dist/
