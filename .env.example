# =============================================================================
# TCG Software — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- SSM Tunnel (optional — set SSM_TUNNEL_ENABLED=true to connect via bastion) ---
# Requires: AWS CLI v2 + Session Manager plugin installed
SSM_TUNNEL_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SSM_BASTION_ID=i-0132f2ba5f7ed8c81
DB_REMOTE_HOST=10.0.5.10
DB_REMOTE_PORT=27017
LOCAL_PORT=27017

# --- MongoDB credentials (used when SSM_TUNNEL_ENABLED=true) ---
# The URI is assembled automatically: mongodb://USER:PASS@localhost:LOCAL_PORT/DB?authSource=AUTH_SOURCE
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_DB=tcg-instrument

# --- MongoDB direct connection (used when SSM_TUNNEL_ENABLED=false) ---
# Set the full URI directly when connecting without the SSM tunnel
MONGO_URI=
MONGO_DB_NAME=tcg-instrument

# --- Write layer (optional) ---
# When tunnel is enabled: set MONGO_APP_WRITE_USER and MONGO_APP_WRITE_PASSWORD
# When tunnel is disabled: set MONGO_APP_WRITE_URI directly
MONGO_APP_WRITE_USER=
MONGO_APP_WRITE_PASSWORD=
MONGO_APP_WRITE_URI=
MONGO_APP_WRITE_DB_NAME=tcg-app-data
MONGO_APP_WRITE_COLLECTION=2026-app-data

# --- CORS ---
TCG_CORS_ORIGINS=http://localhost:5173
