# TCG Software — Environment Configuration
# Copy this file to .env and fill in your values.

# MongoDB connection URI (required)
MONGO_URI=mongodb://localhost:27017

# Database name for instrument/price data
MONGO_DB_NAME=tcg-instrument

# (Optional) Separate write URI for app persistence
# MONGO_APP_WRITE_URI=mongodb://localhost:27017

# Database and collection for app-generated data (portfolios, signals, etc.)
MONGO_APP_WRITE_DB_NAME=tcg-app-data
MONGO_APP_WRITE_COLLECTION=2026-app-data
