# MongoDB connection — the legacy tcg-instrument database
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=tcg-instrument

# MongoDB write layer — the dedicated write database and collection
MONGO_APP_WRITE_URI=mongodb://app-writer:<PASSWORD>@localhost:27017/tcg-app-data?authSource=tcg-app-data
MONGO_APP_WRITE_DB_NAME=tcg-app-data
MONGO_APP_WRITE_COLLECTION=2026-app-data
