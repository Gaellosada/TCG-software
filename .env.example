# =============================================================================
# TCG Software — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- dwh PostgreSQL warehouse (REQUIRED — market data: instruments, prices, options, greeks) ---
# Instrument/market reads come from the dwh warehouse (read-only). Startup fails fast if
# DWH_HOST / DWH_USER / DWH_PASSWORD are unset. Point DWH_HOST at the RDS endpoint directly
# where reachable, or at localhost + a forwarded port if you connect through a tunnel.
DWH_HOST=
DWH_USER=
DWH_PASSWORD=
DWH_PORT=5432
DWH_DB=dwh
DWH_SSLMODE=require
# DWH_STATEMENT_TIMEOUT_MS=60000

# --- SSM Tunnel (optional — for the app-data MongoDB; set SSM_TUNNEL_ENABLED=true to route via bastion) ---
# Requires: AWS CLI v2 + Session Manager plugin installed
SSM_TUNNEL_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SSM_BASTION_ID=i-0132f2ba5f7ed8c81
DB_REMOTE_HOST=10.0.5.10
DB_REMOTE_PORT=27017
LOCAL_PORT=27017

# --- MongoDB — app-data persistence ONLY (indicators / signals / portfolios) ---
# Market reads moved to dwh (above); MongoDB now stores only app-data.
# Tunnel mode: the write URI is assembled as
#   mongodb://MONGO_APP_WRITE_USER:MONGO_APP_WRITE_PASSWORD@localhost:LOCAL_PORT/?authSource=MONGO_AUTH_SOURCE
# Direct mode (tunnel disabled): set MONGO_APP_WRITE_URI explicitly.
MONGO_AUTH_SOURCE=admin
MONGO_APP_WRITE_USER=
MONGO_APP_WRITE_PASSWORD=
MONGO_APP_WRITE_URI=
MONGO_APP_WRITE_DB_NAME=tcg-app-data
MONGO_APP_WRITE_COLLECTION=2026-app-data

# --- CORS ---
TCG_CORS_ORIGINS=http://localhost:5173
