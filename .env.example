# =============================================================================
# TCG Software — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- dwh PostgreSQL warehouse (REQUIRED — market data: instruments, prices, options, greeks) ---
# Read-only role tcg_read on schema tcg_instruments. Direct connection (no tunnel).
# Startup fails fast if DWH_HOST / DWH_USER / DWH_PASSWORD are unset.
DWH_HOST=
DWH_USER=
DWH_PASSWORD=
DWH_PORT=5432
DWH_DB=dwh
DWH_SSLMODE=require
# DWH_STATEMENT_TIMEOUT_MS=60000

# --- app-data PostgreSQL (read-write: indicators / signals / portfolios / baskets) ---
# Same RDS + dwh database as market data; schema tcg_app_data; role tcg_app_rw.
APP_DB_USER=
APP_DB_PASSWORD=
APP_DB_SCHEMA=tcg_app_data
# Host/port/db default to DWH_HOST/DWH_PORT/DWH_DB; uncomment only to override:
# APP_DB_HOST=
# APP_DB_PORT=5432
# APP_DB_NAME=dwh

# --- CORS ---
TCG_CORS_ORIGINS=http://localhost:5173
