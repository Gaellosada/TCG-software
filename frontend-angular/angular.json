{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "tcg-frontend": {
      "projectType": "library",
      "root": "projects/tcg-frontend",
      "sourceRoot": "projects/tcg-frontend/src",
      "prefix": "tcg",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/tcg-frontend/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/tcg-frontend/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/tcg-frontend/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/tcg-frontend/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "dev-harness": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/dev-harness",
      "sourceRoot": "projects/dev-harness/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/dev-harness",
            "index": "projects/dev-harness/src/index.html",
            "browser": "projects/dev-harness/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/dev-harness/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dev-harness/public"
              }
            ],
            "styles": [
              "projects/dev-harness/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "dev-harness:build:production"
            },
            "development": {
              "buildTarget": "dev-harness:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/dev-harness/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dev-harness/public"
              }
            ],
            "styles": [
              "projects/dev-harness/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
